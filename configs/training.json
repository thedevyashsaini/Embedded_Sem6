{
    "_comment": "Training hyper-parameters for all HAR models.",
    "epochs": 30,
    "batch_size": 64,
    "learning_rate": 0.001,
    "validation_split": 0.2,
    "random_seed": 42,
    "optimizer": "adam",
    "loss": "sparse_categorical_crossentropy",

    "models": {
        "1dcnn": {
            "_comment": "Lightweight 1D-CNN on 19 pre-extracted features.",
            "data_mode": "features",
            "input_length": 19,
            "conv_filters": 12,
            "conv_kernel_size": 19,
            "conv_stride": 1,
            "conv_padding": "valid",
            "conv_activation": "relu",
            "num_classes": 5,
            "output_activation": "softmax"
        },
        "cnn_lstm": {
            "_comment": "CNN+LSTM (DCLSTM) on raw 128x9 inertial signals.",
            "data_mode": "raw",
            "input_timesteps": 128,
            "input_channels": 9,
            "conv1_filters": 64,
            "conv1_kernel_size": 5,
            "conv2_filters": 64,
            "conv2_kernel_size": 5,
            "conv_activation": "relu",
            "lstm_units": 128,
            "dropout_rate": 0.3,
            "num_classes": 5,
            "output_activation": "softmax"
        },
        "wclstm": {
            "_comment": "Wavelet-CNN+LSTM on wavelet-decomposed 128x9 signals.",
            "data_mode": "wavelet",
            "wavelet": "db4",
            "wavelet_level": 2,
            "input_channels": 9,
            "conv1_filters": 64,
            "conv1_kernel_size": 5,
            "conv2_filters": 64,
            "conv2_kernel_size": 5,
            "conv_activation": "relu",
            "lstm_units": 128,
            "dropout_rate": 0.3,
            "num_classes": 5,
            "output_activation": "softmax"
        }
    },

    "label_map": {
        "1": 0,
        "2": 0,
        "3": 0,
        "4": 1,
        "5": 2,
        "6": 3
    },
    "class_names": ["WALKING", "SITTING", "STANDING", "LAYING", "TRANSITION"]
}
