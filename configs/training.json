{
    "_comment": "Training hyper-parameters for the lightweight 1D-CNN HAR model.",
    "epochs": 30,
    "batch_size": 64,
    "learning_rate": 0.001,
    "validation_split": 0.2,
    "random_seed": 42,
    "optimizer": "adam",
    "loss": "sparse_categorical_crossentropy",

    "model": {
        "input_length": 19,
        "conv_filters": 12,
        "conv_kernel_size": 19,
        "conv_stride": 1,
        "conv_padding": "valid",
        "conv_activation": "relu",
        "num_classes": 5,
        "output_activation": "softmax"
    },

    "label_map": {
        "1": 0,
        "2": 0,
        "3": 0,
        "4": 1,
        "5": 2,
        "6": 3
    },
    "class_names": ["WALKING", "SITTING", "STANDING", "LAYING", "TRANSITION"]
}
